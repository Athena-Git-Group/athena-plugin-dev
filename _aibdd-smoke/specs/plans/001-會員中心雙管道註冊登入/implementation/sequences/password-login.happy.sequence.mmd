%% Trace: features/01-聯絡身分檢查.feature + features/02-密碼登入.feature
sequenceDiagram
    actor User
    participant FE as Frontend
    participant Ctrl as LoginController
    participant Svc as ContactIdentityService
    participant LoginSvc as PasswordLoginService
    participant Throttle as LoginThrottleService
    participant CRM as CrmCustomerGateway
    participant Repo as MemberAuthRepository
    participant JwtIssuer as JwtTokenService
    participant DB as PostgreSQL

    %% --- Stage 1: check-contact-identity ---
    User->>FE: 第一階段輸入 Email 或手機
    FE->>Ctrl: POST /check-contact-identity (contact)
    Ctrl->>Svc: classify(contact)
    Svc->>Repo: findByEmailHashOrMobileHash(hash, is_deleted=false)
    Repo->>DB: SELECT member_auths WHERE ... AND is_deleted = false
    DB-->>Repo: member_auth (exists)
    Repo-->>Svc: member_auth
    Svc-->>Ctrl: LOGIN
    Ctrl-->>FE: 200 {result: LOGIN, masked_existing_email?: null}

    %% --- Stage 2: password login ---
    User->>FE: 第二階段輸入密碼 + Captcha
    FE->>Ctrl: POST /login (contact, password, captcha)
    Ctrl->>LoginSvc: authenticate(contact, password)
    LoginSvc->>Throttle: isAccountThrottled(contact)
    Throttle-->>LoginSvc: false
    LoginSvc->>Repo: findByContact(contact)
    Repo->>DB: SELECT member_auths
    DB-->>Repo: row(password_hash)
    Repo-->>LoginSvc: member_auth
    LoginSvc->>LoginSvc: verifyHash(password, password_hash)
    LoginSvc->>JwtIssuer: issue(subject=member_auth.id)
    JwtIssuer-->>LoginSvc: access_token
    LoginSvc-->>Ctrl: SessionToken
    Ctrl-->>FE: 200 {access_token}
    FE-->>User: 進入會員中心
