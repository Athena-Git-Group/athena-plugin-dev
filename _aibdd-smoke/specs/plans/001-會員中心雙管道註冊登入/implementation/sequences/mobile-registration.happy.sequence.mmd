%% Trace: features/02-手機註冊發送OTP.feature + features/03-手機註冊完成驗證.feature
sequenceDiagram
    actor User
    participant FE as Frontend
    participant Ctrl as SignUpController
    participant Svc as MemberRegistrationService
    participant OtpSvc as OtpService
    participant SMS as ItSmsGateway
    participant CRM as CrmCustomerGateway
    participant Repo as MemberAuthRepository
    participant OtpRepo as OtpRecordRepository
    participant DB as PostgreSQL

    %% --- Phase 1: send OTP (sign-up/mobile) ---
    User->>FE: 輸入手機 + 密碼 (BR-27 正規化)
    FE->>Ctrl: POST /sign-up/mobile (mobile, password, captcha)
    Ctrl->>Svc: requestRegisterOtp(mobile)
    Svc->>OtpSvc: issue(contact=mobile, purpose=REGISTER, channel=sms)
    OtpSvc->>OtpRepo: insert OtpRecord(uuid, purpose=REGISTER, contact_hash, expires_at)
    OtpRepo->>DB: INSERT otp_records
    OtpSvc->>SMS: enqueue SMS_SEND_INFO_LIST(mobile, code)
    OtpSvc-->>Svc: otp_uuid
    Svc-->>Ctrl: otp_uuid
    Ctrl-->>FE: 200 {otp_uuid}

    %% --- Phase 2: verify OTP + create account (verify-otp REGISTER) ---
    User->>FE: 輸入收到的 OTP
    FE->>Ctrl: POST /verify-otp (otp_uuid, otp_code, purpose=REGISTER)
    Ctrl->>Svc: completeMobileRegistration(otp_uuid, code)
    Svc->>OtpSvc: verify(otp_uuid, code, purpose=REGISTER)
    OtpSvc->>OtpRepo: SELECT otp_records WHERE otp_uuid AND purpose='REGISTER' AND used_at IS NULL
    OtpRepo-->>OtpSvc: record (valid)
    OtpSvc->>OtpRepo: UPDATE used_at = now()
    OtpSvc-->>Svc: ok (contact_hash=mobile_hash)
    Svc->>CRM: lookupCustomer(mobileHash)
    CRM-->>Svc: NONE (NEW)
    Svc->>CRM: createCustomer(mobile)
    CRM-->>Svc: customer_id
    Svc->>Repo: insert MemberAuth(customer_id, mobile, mobile_phone_hash, password_hash)
    Repo->>DB: INSERT member_auths
    Svc->>Repo: insert MemberCenterProfile(member_auth_id)
    Repo->>DB: INSERT member_center_profiles
    Svc-->>Ctrl: registered
    Ctrl-->>FE: 201 Created
    FE-->>User: 註冊成功
