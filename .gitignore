.DS_Store
*.swp
*.swo
*~
.env
node_modules/
__pycache__/
*.pyc

# Athena runtime artifacts — generated by /athena-flow inside consumer
# projects. The plugin dog-foods itself here, so these dirs exist locally
# but should never be committed into the plugin repo. If you ever want to
# ship one as an example, move it to examples/ explicitly.
/handoffs/
/points/
/requirement-feedback/
/plans/

# /codemap (graphify) runtime artifacts — per-user knowledge graph cache.
# Each consumer regenerates locally; never commit.
/graphify-out/

# Per-author Claude Code overrides. settings.json (without .local) is the
# committed baseline shared by all plugin authors.
.claude/settings.local.json
